# Database Configuration
# Database credentials must be provided via environment variables:
# DB_URL, DB_USERNAME, DB_PASSWORD
# Example: DB_URL=jdbc:postgresql://localhost:5432/smart_parking_db DB_USERNAME=postgres DB_PASSWORD=yourSecurePassword
spring.datasource.url=${DB_URL:jdbc:postgresql://localhost:5432/smart_parking_db}
spring.datasource.username=${DB_USERNAME:postgres}
spring.datasource.password=${DB_PASSWORD}
spring.datasource.driver-class-name=org.postgresql.Driver

# JPA Configuration
spring.jpa.hibernate.ddl-auto=update
spring.jpa.show-sql=true
spring.jpa.properties.hibernate.dialect=org.hibernate.dialect.PostgreSQLDialect
spring.jpa.properties.hibernate.format_sql=true
spring.jpa.defer-datasource-initialization=true

# Hibernate Debug Logging
logging.level.org.hibernate.SQL=DEBUG
logging.level.org.hibernate.type.descriptor.sql=TRACE

# Server Configuration
server.port=8081
# server.servlet.context-path=/api

# Authentication Configuration
# Credentials must be provided via environment variables:
# AUTH_EXIT_USER, AUTH_EXIT_PASSWORD, AUTH_ADMIN_USER, AUTH_ADMIN_PASSWORD
# Example: AUTH_EXIT_USER=exit AUTH_EXIT_PASSWORD=yourSecurePassword
auth.exit.user=${AUTH_EXIT_USER}
auth.exit.password=${AUTH_EXIT_PASSWORD}
auth.admin.user=${AUTH_ADMIN_USER}
auth.admin.password=${AUTH_ADMIN_PASSWORD}

# JWT Configuration
# JWT secret must be provided via environment variable: JWT_SECRET
# Generate a secure random key for production
jwt.secret=${JWT_SECRET}
jwt.expiration=86400000

# Cache Configuration
spring.cache.type=jcache
spring.cache.jcache.provider=org.ehcache.jsr107.EhcacheCachingProvider

# Rate Limiting Configuration (Updated for better user experience)
rate.limit.lock.requests=50
rate.limit.book.requests=30
rate.limit.view.requests=200
rate.limit.duration.minutes=5

# CORS Configuration
app.cors.allowed-origins=http://localhost:8081

# Log Level Configuration
logging.level.com.smartparking=DEBUG
logging.level.org.springframework.web=DEBUG
logging.level.org.springframework.security=DEBUG
